{
    "ServiceName": "saarthiai-backend-service",
    "SourceConfiguration": {
        "CodeRepository": {
            "RepositoryUrl": "https://github.com/Awnish-sahdeo/backend-sarthi.git",
            "SourceCodeVersion": {
                "Type": "BRANCH",
                "Value": "main"
            },
            "CodeConfiguration": {
                "ConfigurationSource": "API",
                "CodeConfigurationValues": {
                    "Runtime": "PYTHON_311",
                    "BuildCommand": "pip install --upgrade pip && pip install -r requirements.txt",
                    "StartCommand": "python -m uvicorn app.main:app --host 0.0.0.0 --port 8000",
                    "Port": "8000",
                    "RuntimeEnvironmentVariables": {
                        "PYTHONPATH": ".",
                        "ENV": "production"
                    }
                }
            }
        }
    },
    "Tags": {
        "Environment": "production",
        "Project": "SaarthiAI",
        "Service": "backend"
    }
}
