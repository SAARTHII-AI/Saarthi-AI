ENV=development
API_HOST=0.0.0.0
API_PORT=8000
OFFLINE_ONLY=false

# Azure OpenAI (leave blank to use offline answer path only)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# Bright Data SERP (optional; skipped if token or zone missing)
BRIGHTDATA_API_TOKEN=
BRIGHTDATA_SERP_ZONE=

# Bright Data Datacenter Proxy (optional)
BRIGHTDATA_DC_HOST=
BRIGHTDATA_DC_PORT=
BRIGHTDATA_DC_USER=
BRIGHTDATA_DC_PASS=
