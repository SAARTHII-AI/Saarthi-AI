# --- Local server (optional) ---
ENV=development
API_HOST=0.0.0.0
API_PORT=8000

# Set to true to force local keyword-RAG answers only (no Azure / Bright Data).
OFFLINE_ONLY=false

# --- Azure OpenAI (preferred when configured and OFFLINE_ONLY=false) ---
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_DEPLOYMENT=gpt-5.3-chat
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# --- Bright Data (optional web enrichment via SERP API) ---
# API key from Bright Data account settings (Bearer token).
BRIGHTDATA_API_TOKEN=your-brightdata-api-token
BRIGHTDATA_SERP_ZONE=your-serp-zone-name
# Used by unlocker / future URL-fetch features (optional today).
BRIGHTDATA_UNLOCKER_ZONE=your-unlocker-zone-name

# Optional: override default Bright Data REST endpoint / timeouts.
# BRIGHTDATA_REQUEST_URL=https://api.brightdata.com/request
# BRIGHTDATA_SERP_TIMEOUT_SECONDS=25

# Datacenter proxy (optional; not required for SERP /request API).
BRIGHTDATA_DC_HOST=brd.superproxy.io
BRIGHTDATA_DC_PORT=33335
BRIGHTDATA_DC_USER=brd-customer-hl_your-zone-user
BRIGHTDATA_DC_PASS=your-dc-proxy-password

# --- Azure Speech/Cognitive Services (for TTS and STT) ---
# Required for server-side text-to-speech and speech-to-text.
# Get your keys from: https://portal.azure.com (Create a Speech resource)
# Falls back to browser Web Speech API when not configured.
AZURE_SPEECH_KEY=your-azure-speech-key
AZURE_SPEECH_REGION=centralindia

# Optional: Azure Blob Storage for storing audio files (if needed for caching)
# AZURE_BLOB_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
