modules = ["python-3.12", "nodejs-20", "web"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[[ports]]
localPort = 3000
externalPort = 3000

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 3002
externalPort = 3002

[[ports]]
localPort = 3003
externalPort = 3003

[[ports]]
localPort = 3005
externalPort = 4200

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8000
externalPort = 8000
exposeLocalhost = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python server.py"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[deployment]
deploymentTarget = "autoscale"
run = ["sh", "-c", "cd backend && python -m uvicorn app.main:app --host 0.0.0.0 --port ${PORT:-80}"]
build = ["sh", "-c", "pip install -r requirements.txt && cp -r frontend backend/frontend_dist"]

[userenv]

[userenv.shared]
ENV = "development"
API_HOST = "0.0.0.0"
API_PORT = "8000"
OFFLINE_ONLY = "false"
AZURE_OPENAI_ENDPOINT = "https://aditjain2005-0132-resource.openai.azure.com"
AZURE_OPENAI_DEPLOYMENT = "gpt-5.3-chat"
AZURE_OPENAI_API_VERSION = "2025-01-01-preview"
BRIGHTDATA_SERP_ZONE = "serp_api1"
BRIGHTDATA_DC_HOST = "brd.superproxy.io"
BRIGHTDATA_DC_PORT = "33335"
BRIGHTDATA_DC_USER = "brd-customer-hl_68343586-zone-datacenter_proxy1"
AZURE_TRANSLATOR_REGION = "eastasia"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 60000
